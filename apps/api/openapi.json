{
  "openapi": "3.0.0",
  "paths": {
    "/api/v1/status": {
      "get": {
        "operationId": "getApiInfoV1",
        "parameters": [],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GetApiInfoResponse"
                }
              }
            }
          }
        },
        "summary": "",
        "tags": [
          "status"
        ]
      }
    },
    "/api/v1/github-app/manifest": {
      "get": {
        "operationId": "getGithubAppManifestV1",
        "parameters": [],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GetManifestResponse"
                }
              }
            }
          }
        },
        "summary": "",
        "tags": [
          "github-app"
        ]
      }
    },
    "/api/v1/github-app/conversions": {
      "post": {
        "operationId": "convertGithubAppManifestV1",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ConvertManifestCommand"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ConvertManifestResponse"
                }
              }
            }
          }
        },
        "summary": "",
        "tags": [
          "github-app"
        ]
      }
    }
  },
  "info": {
    "title": "Marsa API",
    "description": "Marsa PaaS HTTP API",
    "version": "1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "schemas": {
      "GetApiInfoResponse": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "marsa-api"
          },
          "version": {
            "type": "string",
            "example": "0.0.0"
          },
          "commit": {
            "type": "string",
            "nullable": true
          },
          "nodeEnv": {
            "type": "string",
            "example": "development"
          },
          "uptimeSeconds": {
            "type": "number",
            "example": 12
          }
        },
        "required": [
          "name",
          "version",
          "commit",
          "nodeEnv",
          "uptimeSeconds"
        ]
      },
      "GetManifestResponse": {
        "type": "object",
        "properties": {
          "manifest": {
            "type": "object",
            "additionalProperties": true,
            "description": "GitHub App manifest — the FE posts this as the `manifest` form field."
          },
          "formAction": {
            "type": "string",
            "example": "https://github.com/settings/apps/new?state=abc123",
            "description": "Form action the FE submits the manifest to."
          },
          "state": {
            "type": "string",
            "description": "Signed CSRF state; echoed back by GitHub on the callback."
          }
        },
        "required": [
          "manifest",
          "formAction",
          "state"
        ]
      },
      "ConvertManifestCommand": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string",
            "description": "Temporary code from the GitHub redirect."
          },
          "state": {
            "type": "string",
            "description": "Signed CSRF state echoed back by GitHub."
          }
        },
        "required": [
          "code",
          "state"
        ]
      },
      "ConvertManifestResponse": {
        "type": "object",
        "properties": {
          "appSlug": {
            "type": "string",
            "example": "marsa-demo-marsa-cc"
          },
          "appName": {
            "type": "string",
            "example": "marsa-demo.marsa.cc"
          },
          "htmlUrl": {
            "type": "string",
            "example": "https://github.com/apps/marsa-demo-marsa-cc"
          },
          "installUrl": {
            "type": "string",
            "description": "Where the operator installs the App on their repos (#23).",
            "example": "https://github.com/apps/marsa-demo-marsa-cc/installations/new"
          }
        },
        "required": [
          "appSlug",
          "appName",
          "htmlUrl",
          "installUrl"
        ]
      }
    }
  }
}
