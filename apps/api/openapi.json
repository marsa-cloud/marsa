{
  "openapi": "3.0.0",
  "paths": {
    "/api/v1/status": {
      "get": {
        "operationId": "getApiInfoV1",
        "parameters": [],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GetApiInfoResponse"
                }
              }
            }
          }
        },
        "summary": "",
        "tags": [
          "status"
        ]
      }
    },
    "/api/v1/github-app/manifest": {
      "get": {
        "operationId": "getGithubAppManifestV1",
        "parameters": [],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GetManifestResponse"
                }
              }
            }
          }
        },
        "summary": "",
        "tags": [
          "github-app"
        ]
      }
    },
    "/api/v1/github-app/convert-manifest": {
      "post": {
        "operationId": "convertGithubAppManifestV1",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ConvertManifestCommand"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ConvertManifestResponse"
                }
              }
            }
          },
          "400": {
            "description": "Malformed body, or an invalid/expired state token."
          },
          "502": {
            "description": "GitHub App creation failed upstream at GitHub."
          }
        },
        "summary": "",
        "tags": [
          "github-app"
        ]
      }
    },
    "/api/v1/github-app/capture-installation": {
      "post": {
        "operationId": "captureGithubAppInstallationV1",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CaptureInstallationCommand"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CaptureInstallationResponse"
                }
              }
            }
          },
          "400": {
            "description": "Malformed body, an unsupported setup_action, or no provisioned App."
          },
          "502": {
            "description": "The installation could not be verified with GitHub."
          }
        },
        "summary": "",
        "tags": [
          "github-app"
        ]
      }
    },
    "/api/v1/auth/github": {
      "get": {
        "operationId": "beginGithubLoginV1",
        "parameters": [],
        "responses": {
          "302": {
            "description": "Redirects to GitHub OAuth consent."
          },
          "400": {
            "description": "No provisioned GitHub App — create the App first."
          }
        },
        "summary": "",
        "tags": [
          "auth"
        ]
      }
    },
    "/api/v1/auth/github/session": {
      "post": {
        "operationId": "completeGithubLoginV1",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CompleteGithubLoginCommand"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CompleteGithubLoginResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid/expired OAuth state, or no provisioned App."
          },
          "502": {
            "description": "Could not complete login with GitHub."
          }
        },
        "summary": "",
        "tags": [
          "auth"
        ]
      }
    },
    "/api/v1/auth/me": {
      "get": {
        "operationId": "getCurrentOperatorV1",
        "parameters": [],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GetCurrentOperatorResponse"
                }
              }
            }
          },
          "401": {
            "description": "No active session."
          }
        },
        "summary": "",
        "tags": [
          "auth"
        ]
      }
    }
  },
  "info": {
    "title": "Marsa API",
    "description": "Marsa PaaS HTTP API",
    "version": "1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "schemas": {
      "GetApiInfoResponse": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "marsa-api"
          },
          "version": {
            "type": "string",
            "example": "0.0.0"
          },
          "commit": {
            "type": "string",
            "nullable": true
          },
          "nodeEnv": {
            "type": "string",
            "example": "development"
          },
          "uptimeSeconds": {
            "type": "number",
            "example": 12
          }
        },
        "required": [
          "name",
          "version",
          "commit",
          "nodeEnv",
          "uptimeSeconds"
        ]
      },
      "HookAttributesDto": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string",
            "description": "Webhook delivery URL."
          }
        },
        "required": [
          "url"
        ]
      },
      "ManifestDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "url": {
            "type": "string"
          },
          "hook_attributes": {
            "$ref": "#/components/schemas/HookAttributesDto"
          },
          "redirect_url": {
            "type": "string"
          },
          "callback_urls": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "public": {
            "type": "boolean"
          },
          "request_oauth_on_install": {
            "type": "boolean"
          },
          "default_permissions": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          },
          "default_events": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "name",
          "url",
          "hook_attributes",
          "redirect_url",
          "callback_urls",
          "public",
          "request_oauth_on_install",
          "default_permissions",
          "default_events"
        ]
      },
      "GetManifestResponse": {
        "type": "object",
        "properties": {
          "manifest": {
            "description": "GitHub App manifest — the FE posts this as the `manifest` form field.",
            "allOf": [
              {
                "$ref": "#/components/schemas/ManifestDto"
              }
            ]
          },
          "formAction": {
            "type": "string",
            "example": "https://github.com/settings/apps/new?state=abc123",
            "description": "Form action the FE submits the manifest to."
          },
          "state": {
            "type": "string",
            "description": "Single-use CSRF state token (DB-backed, expires in 10 min); echoed back by GitHub on the callback."
          }
        },
        "required": [
          "manifest",
          "formAction",
          "state"
        ]
      },
      "ConvertManifestCommand": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string",
            "description": "Temporary code from the GitHub redirect."
          },
          "state": {
            "type": "string",
            "description": "Signed CSRF state echoed back by GitHub."
          }
        },
        "required": [
          "code",
          "state"
        ]
      },
      "ConvertManifestResponse": {
        "type": "object",
        "properties": {
          "appSlug": {
            "type": "string",
            "example": "marsa-demo-marsa-cc"
          },
          "appName": {
            "type": "string",
            "example": "marsa-demo.marsa.cc"
          },
          "htmlUrl": {
            "type": "string",
            "example": "https://github.com/apps/marsa-demo-marsa-cc"
          },
          "installUrl": {
            "type": "string",
            "description": "Where the operator installs the App on their repos (#23).",
            "example": "https://github.com/apps/marsa-demo-marsa-cc/installations/new"
          }
        },
        "required": [
          "appSlug",
          "appName",
          "htmlUrl",
          "installUrl"
        ]
      },
      "CaptureInstallationCommand": {
        "type": "object",
        "properties": {
          "installationId": {
            "type": "string",
            "description": "GitHub's numeric installation id from the post-install redirect.",
            "pattern": "^\\d+$",
            "example": "88776655"
          },
          "setupAction": {
            "type": "string",
            "description": "GitHub's `setup_action` query param (expected: `install`).",
            "enum": [
              "install"
            ],
            "example": "install"
          }
        },
        "required": [
          "installationId",
          "setupAction"
        ]
      },
      "CaptureInstallationResponse": {
        "type": "object",
        "properties": {
          "installationId": {
            "type": "string",
            "example": "88776655"
          },
          "accountLogin": {
            "type": "string",
            "nullable": true,
            "example": "octo-org"
          },
          "connected": {
            "type": "boolean",
            "description": "True once the installation is captured and its access verified.",
            "example": true
          }
        },
        "required": [
          "installationId",
          "accountLogin",
          "connected"
        ]
      },
      "CompleteGithubLoginCommand": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string",
            "description": "GitHub's user-OAuth authorization code from the consent redirect."
          },
          "state": {
            "type": "string",
            "description": "The CSRF state issued by `GET /auth/github`, echoed back by GitHub."
          }
        },
        "required": [
          "code",
          "state"
        ]
      },
      "CompleteGithubLoginResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "1"
          },
          "login": {
            "type": "string",
            "example": "octocat"
          }
        },
        "required": [
          "id",
          "login"
        ]
      },
      "GetCurrentOperatorResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "1"
          },
          "login": {
            "type": "string",
            "example": "octocat"
          }
        },
        "required": [
          "id",
          "login"
        ]
      }
    }
  }
}
