{
  "openapi": "3.0.0",
  "paths": {
    "/api/v1/status": {
      "get": {
        "operationId": "getApiInfoV1",
        "parameters": [],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GetApiInfoResponse"
                }
              }
            }
          }
        },
        "tags": [
          "status"
        ]
      }
    },
    "/api/v1/github-app/manifest": {
      "get": {
        "operationId": "getManifestV1",
        "parameters": [],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GetManifestResponse"
                }
              }
            }
          }
        },
        "tags": [
          "github-app"
        ]
      }
    },
    "/api/v1/github-app/convert-manifest": {
      "post": {
        "operationId": "convertManifestV1",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ConvertManifestCommand"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ConvertManifestResponse"
                }
              }
            }
          },
          "400": {
            "description": "Malformed body, or an invalid/expired state token."
          },
          "502": {
            "description": "GitHub App creation failed upstream at GitHub."
          }
        },
        "tags": [
          "github-app"
        ]
      }
    },
    "/api/v1/github-app/capture-installation": {
      "post": {
        "operationId": "captureInstallationV1",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CaptureInstallationCommand"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CaptureInstallationResponse"
                }
              }
            }
          },
          "400": {
            "description": "Malformed body, an unsupported setup_action, or no provisioned App."
          },
          "502": {
            "description": "The installation could not be verified with GitHub."
          }
        },
        "tags": [
          "github-app"
        ]
      }
    },
    "/api/v1/auth/github": {
      "get": {
        "operationId": "beginGithubLoginV1",
        "parameters": [],
        "responses": {
          "302": {
            "description": "Redirects to GitHub OAuth consent, or to the setup wizard when no App is provisioned."
          }
        },
        "tags": [
          "auth"
        ]
      }
    },
    "/api/v1/auth/github/session": {
      "post": {
        "operationId": "completeGithubLoginV1",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CompleteGithubLoginCommand"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CompleteGithubLoginResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid/expired OAuth state, or no provisioned App."
          },
          "502": {
            "description": "Could not complete login with GitHub."
          }
        },
        "tags": [
          "auth"
        ]
      }
    },
    "/api/v1/auth/me": {
      "get": {
        "operationId": "viewMeV1",
        "parameters": [],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ViewMeResponse"
                }
              }
            }
          },
          "401": {
            "description": "No active session."
          }
        },
        "tags": [
          "auth"
        ]
      }
    },
    "/api/v1/deploy": {
      "post": {
        "operationId": "deployAppV1",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DeployAppCommand"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DeployAppResponse"
                }
              }
            }
          },
          "400": {
            "description": "Malformed body, or an invalid slug / image / port."
          },
          "401": {
            "description": "No active session."
          }
        },
        "tags": [
          "releases"
        ]
      }
    },
    "/api/v1/apps/{slug}/releases": {
      "get": {
        "operationId": "viewReleaseIndexV1",
        "parameters": [
          {
            "name": "slug",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ViewReleaseIndexResponse"
                }
              }
            }
          },
          "401": {
            "description": "No active session."
          }
        },
        "tags": [
          "releases"
        ]
      }
    },
    "/api/v1/apps": {
      "get": {
        "operationId": "viewAppIndexV1",
        "parameters": [],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ViewAppIndexResponse"
                }
              }
            }
          },
          "401": {
            "description": "No active session."
          }
        },
        "tags": [
          "apps"
        ]
      }
    },
    "/api/v1/apps/{slug}/health": {
      "get": {
        "operationId": "viewAppHealthV1",
        "parameters": [
          {
            "name": "slug",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ViewAppHealthResponse"
                }
              }
            }
          },
          "401": {
            "description": "No active session."
          }
        },
        "tags": [
          "apps"
        ]
      }
    },
    "/api/v1/apps/{slug}/logs": {
      "get": {
        "operationId": "viewAppLogsV1",
        "parameters": [
          {
            "name": "slug",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "tailLines",
            "required": false,
            "in": "query",
            "description": "Trailing log lines to return (default 100).",
            "schema": {
              "minimum": 1,
              "maximum": 1000,
              "example": 100,
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ViewAppLogsResponse"
                }
              }
            }
          },
          "400": {
            "description": "tailLines out of range (1–1000) or not an integer."
          },
          "401": {
            "description": "No active session."
          }
        },
        "tags": [
          "apps"
        ]
      }
    }
  },
  "info": {
    "title": "Marsa API",
    "description": "Marsa PaaS HTTP API",
    "version": "0.0.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "schemas": {
      "GetApiInfoResponse": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "marsa-api"
          },
          "version": {
            "type": "string",
            "example": "0.0.0"
          },
          "commit": {
            "type": "string",
            "nullable": true
          },
          "nodeEnv": {
            "type": "string",
            "example": "development"
          },
          "uptimeSeconds": {
            "type": "number",
            "example": 12
          }
        },
        "required": [
          "name",
          "version",
          "commit",
          "nodeEnv",
          "uptimeSeconds"
        ]
      },
      "HookAttributesDto": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string",
            "description": "Webhook delivery URL."
          }
        },
        "required": [
          "url"
        ]
      },
      "ManifestDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "url": {
            "type": "string"
          },
          "hook_attributes": {
            "$ref": "#/components/schemas/HookAttributesDto"
          },
          "redirect_url": {
            "type": "string"
          },
          "callback_urls": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "public": {
            "type": "boolean"
          },
          "request_oauth_on_install": {
            "type": "boolean"
          },
          "default_permissions": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          },
          "default_events": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "name",
          "url",
          "hook_attributes",
          "redirect_url",
          "callback_urls",
          "public",
          "request_oauth_on_install",
          "default_permissions",
          "default_events"
        ]
      },
      "GetManifestResponse": {
        "type": "object",
        "properties": {
          "manifest": {
            "description": "GitHub App manifest — the FE posts this as the `manifest` form field.",
            "allOf": [
              {
                "$ref": "#/components/schemas/ManifestDto"
              }
            ]
          },
          "formAction": {
            "type": "string",
            "example": "https://github.com/settings/apps/new?state=abc123",
            "description": "Form action the FE submits the manifest to."
          },
          "state": {
            "type": "string",
            "description": "Single-use CSRF state token (DB-backed, expires in 10 min); echoed back by GitHub on the callback."
          }
        },
        "required": [
          "manifest",
          "formAction",
          "state"
        ]
      },
      "ConvertManifestCommand": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string",
            "description": "Temporary code from the GitHub redirect."
          },
          "state": {
            "type": "string",
            "description": "Signed CSRF state echoed back by GitHub."
          }
        },
        "required": [
          "code",
          "state"
        ]
      },
      "ConvertManifestResponse": {
        "type": "object",
        "properties": {
          "appSlug": {
            "type": "string",
            "example": "marsa-demo-marsa-cc"
          },
          "appName": {
            "type": "string",
            "example": "marsa-demo.marsa.cc"
          },
          "htmlUrl": {
            "type": "string",
            "example": "https://github.com/apps/marsa-demo-marsa-cc"
          },
          "installUrl": {
            "type": "string",
            "description": "Where the operator installs the App on their repos (#23).",
            "example": "https://github.com/apps/marsa-demo-marsa-cc/installations/new"
          }
        },
        "required": [
          "appSlug",
          "appName",
          "htmlUrl",
          "installUrl"
        ]
      },
      "CaptureInstallationCommand": {
        "type": "object",
        "properties": {
          "installationId": {
            "type": "string",
            "description": "GitHub's numeric installation id from the post-install redirect.",
            "pattern": "^\\d+$",
            "example": "88776655"
          },
          "setupAction": {
            "type": "string",
            "description": "GitHub's `setup_action` query param (expected: `install`).",
            "enum": [
              "install"
            ],
            "example": "install"
          }
        },
        "required": [
          "installationId",
          "setupAction"
        ]
      },
      "CaptureInstallationResponse": {
        "type": "object",
        "properties": {
          "installationId": {
            "type": "string",
            "example": "88776655"
          },
          "accountLogin": {
            "type": "string",
            "nullable": true,
            "example": "octo-org"
          },
          "connected": {
            "type": "boolean",
            "description": "True once the installation is captured and its access verified.",
            "example": true
          }
        },
        "required": [
          "installationId",
          "accountLogin",
          "connected"
        ]
      },
      "CompleteGithubLoginCommand": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string",
            "description": "GitHub's user-OAuth authorization code from the consent redirect."
          },
          "state": {
            "type": "string",
            "description": "The CSRF state issued by `GET /auth/github`, echoed back by GitHub."
          }
        },
        "required": [
          "code",
          "state"
        ]
      },
      "CompleteGithubLoginResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "1"
          },
          "login": {
            "type": "string",
            "example": "octocat"
          }
        },
        "required": [
          "id",
          "login"
        ]
      },
      "UserRole": {
        "type": "string",
        "enum": [
          "operator",
          "member"
        ]
      },
      "ViewMeResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "1"
          },
          "login": {
            "type": "string",
            "example": "octocat"
          },
          "role": {
            "example": "operator",
            "allOf": [
              {
                "$ref": "#/components/schemas/UserRole"
              }
            ]
          }
        },
        "required": [
          "id",
          "login",
          "role"
        ]
      },
      "ImagePullCredentials": {
        "type": "object",
        "properties": {
          "registry": {
            "type": "string",
            "maxLength": 253,
            "example": "ghcr.io",
            "description": "Registry host the credentials authenticate against."
          },
          "username": {
            "type": "string",
            "maxLength": 255,
            "example": "my-org",
            "description": "Registry username — an account username, or a registry sentinel (e.g. `AWS`, `_json_key`)."
          },
          "password": {
            "type": "string",
            "format": "password",
            "writeOnly": true,
            "maxLength": 4096,
            "example": "ghp_xxxxxxxxxxxxxxxxxxxx",
            "description": "Password or access token (PAT / API key) — placed in the dockerconfigjson `auth` field."
          }
        },
        "required": [
          "registry",
          "username",
          "password"
        ]
      },
      "DeployAppCommand": {
        "type": "object",
        "properties": {
          "slug": {
            "type": "string",
            "example": "my-app",
            "description": "Public subdomain label + K8s object name.",
            "pattern": "^[a-z0-9]([-a-z0-9]*[a-z0-9])?$",
            "maxLength": 63
          },
          "image": {
            "type": "string",
            "example": "nginx:1.27",
            "description": "Fully-qualified public image ref."
          },
          "containerPort": {
            "type": "integer",
            "example": 80,
            "description": "Port the container listens on.",
            "minimum": 1,
            "maximum": 65535
          },
          "replicas": {
            "type": "integer",
            "example": 1,
            "description": "Replica count (defaults to 1).",
            "minimum": 1,
            "maximum": 100
          },
          "env": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            },
            "example": {
              "LOG_LEVEL": "info"
            },
            "description": "Plain (non-secret) environment variables for the container."
          },
          "imagePullCredentials": {
            "description": "Registry credentials for a private image; encrypted at rest, omitted for public images.",
            "allOf": [
              {
                "$ref": "#/components/schemas/ImagePullCredentials"
              }
            ]
          }
        },
        "required": [
          "slug",
          "image",
          "containerPort"
        ]
      },
      "DeployStatus": {
        "type": "string",
        "enum": [
          "pending",
          "in_progress",
          "succeeded",
          "failed"
        ]
      },
      "DeployAppResponse": {
        "type": "object",
        "properties": {
          "appSlug": {
            "type": "string",
            "example": "my-app"
          },
          "url": {
            "type": "string",
            "example": "https://my-app.demo.marsa.cc"
          },
          "releaseUuid": {
            "type": "string",
            "example": "00000000-0000-0000-0000-000000000000",
            "description": "The Release created for this deploy."
          },
          "deployStatus": {
            "allOf": [
              {
                "$ref": "#/components/schemas/DeployStatus"
              }
            ]
          }
        },
        "required": [
          "appSlug",
          "url",
          "releaseUuid",
          "deployStatus"
        ]
      },
      "ReleaseTrigger": {
        "type": "string",
        "enum": [
          "manual",
          "webhook"
        ]
      },
      "ReleaseSummary": {
        "type": "object",
        "properties": {
          "uuid": {
            "type": "string",
            "example": "00000000-0000-0000-0000-000000000000"
          },
          "imageRef": {
            "type": "string",
            "example": "nginx:1.27"
          },
          "triggeredBy": {
            "example": "manual",
            "allOf": [
              {
                "$ref": "#/components/schemas/ReleaseTrigger"
              }
            ]
          },
          "deployStatus": {
            "example": "succeeded",
            "allOf": [
              {
                "$ref": "#/components/schemas/DeployStatus"
              }
            ]
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          },
          "failureReason": {
            "type": "string",
            "nullable": true,
            "description": "Why the deploy failed (live-derived, only on a failed release).",
            "example": "ImagePullBackOff"
          },
          "failureMessage": {
            "type": "string",
            "nullable": true,
            "example": "Back-off pulling image \"nginx:doesnotexist\""
          }
        },
        "required": [
          "uuid",
          "imageRef",
          "triggeredBy",
          "deployStatus",
          "createdAt",
          "updatedAt"
        ]
      },
      "ViewReleaseIndexResponse": {
        "type": "object",
        "properties": {
          "releases": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ReleaseSummary"
            }
          }
        },
        "required": [
          "releases"
        ]
      },
      "AppSummary": {
        "type": "object",
        "properties": {
          "slug": {
            "type": "string",
            "example": "my-app"
          },
          "image": {
            "type": "string",
            "example": "nginx:1.27"
          },
          "url": {
            "type": "string",
            "example": "https://my-app.demo.marsa.cc"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "slug",
          "image",
          "url",
          "createdAt",
          "updatedAt"
        ]
      },
      "ViewAppIndexResponse": {
        "type": "object",
        "properties": {
          "apps": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AppSummary"
            }
          }
        },
        "required": [
          "apps"
        ]
      },
      "AppHealthStatus": {
        "type": "string",
        "enum": [
          "healthy",
          "degraded",
          "unavailable",
          "not_found"
        ]
      },
      "ViewAppHealthResponse": {
        "type": "object",
        "properties": {
          "status": {
            "example": "healthy",
            "allOf": [
              {
                "$ref": "#/components/schemas/AppHealthStatus"
              }
            ]
          },
          "availableReplicas": {
            "type": "number",
            "example": 1
          },
          "desiredReplicas": {
            "type": "number",
            "example": 1
          }
        },
        "required": [
          "status",
          "availableReplicas",
          "desiredReplicas"
        ]
      },
      "ViewAppLogsResponse": {
        "type": "object",
        "properties": {
          "podName": {
            "type": "string",
            "nullable": true,
            "example": "my-app-7d9c8b6f5-abcde",
            "description": "Pod the log was read from; null when no pod was found."
          },
          "logs": {
            "type": "string",
            "example": "Listening on :8080\n"
          }
        },
        "required": [
          "podName",
          "logs"
        ]
      }
    }
  }
}
