{
  "name": "api",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "AGPL-3.0",
  "type": "module",
  "imports": {
    "#src/*": "./dist/src/*",
    "#test/*": "./dist/src/test/*"
  },
  "scripts": {
    "clean": "rimraf ./dist",
    "build": "nest build",
    "generate:openapi": "pnpm build && node --env-file=.env dist/src/entrypoints/generate-open-api.js",
    "dev": "nest start --exec \"node --env-file=.env\" --watch",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,test}/**/*.ts\"",
    "lint:fix": "eslint \"{src,test}/**/*.ts\" --fix",
    "typecheck": "tsc --noEmit",
    "migration:create": "node --env-file=.env node_modules/@mikro-orm/cli/cli.js migration:create --config ./dist/src/sql/mikro-orm.config.js",
    "migration:up": "node --env-file=.env node_modules/@mikro-orm/cli/cli.js migration:up --config ./dist/src/sql/mikro-orm.config.js",
    "migration:down": "node --env-file=.env node_modules/@mikro-orm/cli/cli.js migration:down --config ./dist/src/sql/mikro-orm.config.js",
    "test:setup": "node --env-file=.env.test dist/src/test/setup/global-setup.js",
    "test:run": "node --experimental-default-config-file --env-file=.env.test --test \"**/*.test.ts\"",
    "test": "pnpm clean && pnpm build && pnpm test:setup && pnpm test:run"
  },
  "dependencies": {
    "@nestjs/common": "catalog:",
    "@nestjs/core": "catalog:",
    "@nestjs/config": "catalog:",
    "@nestjs/platform-express": "catalog:",
    "@nestjs/swagger": "catalog:",
    "@nestjs/platform-fastify": "^11.1.21",
    "@fastify/secure-session": "^8.2.0",
    "@kubernetes/client-node": "catalog:",
    "@mikro-orm/core": "catalog:",
    "@mikro-orm/migrations": "catalog:",
    "@mikro-orm/nestjs": "catalog:",
    "@mikro-orm/postgresql": "catalog:",
    "@octokit/auth-app": "catalog:",
    "@octokit/request": "catalog:",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.33",
    "@types/qs": "^6.15.1",
    "class-transformer": "catalog:",
    "class-validator": "catalog:",
    "dayjs": "catalog:",
    "fastify": "^5.8.5",
    "joi": "catalog:",
    "pg": "^8.21.0",
    "qs": "^6.15.2",
    "reflect-metadata": "catalog:",
    "rxjs": "catalog:"
  },
  "devDependencies": {
    "@mikro-orm/cli": "catalog:",
    "@nestjs/cli": "catalog:",
    "@nestjs/schematics": "catalog:",
    "@nestjs/testing": "catalog:",
    "@types/express": "catalog:",
    "@types/node": "catalog:",
    "@types/sinon": "catalog:",
    "@types/supertest": "catalog:",
    "expect": "catalog:",
    "globals": "catalog:",
    "rimraf": "^6.1.3",
    "sinon": "catalog:",
    "source-map-support": "catalog:",
    "supertest": "catalog:",
    "ts-loader": "catalog:",
    "ts-node": "catalog:",
    "tsconfig-paths": "catalog:",
    "tsx": "catalog:"
  }
}
