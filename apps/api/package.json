{
  "name": "api",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "AGPL-3.0",
  "type": "module",
  "imports": {
    "#src/*": "./dist/src/*",
    "#test/*": "./dist/src/test/*"
  },
  "scripts": {
    "clean": "rimraf ./dist",
    "build": "nest build",
    "generate:openapi": "pnpm build && node dist/src/entrypoints/generate-open-api.js",
    "dev": "nest start --exec \"node --env-file=.env\" --watch",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,test}/**/*.ts\"",
    "lint:fix": "eslint \"{src,test}/**/*.ts\" --fix",
    "typecheck": "tsc --noEmit",
    "migration:create": "mikro-orm migration:create --config ./dist/src/sql/mikro-orm.config.js",
    "migration:up": "mikro-orm migration:up --config ./dist/src/sql/mikro-orm.config.js",
    "migration:down": "mikro-orm migration:down --config ./dist/src/sql/mikro-orm.config.js",
    "test:setup": "node --env-file=.env.test dist/src/test/setup/global-setup.js",
    "test:run": "node --enable-source-maps --experimental-test-isolation=none --env-file=.env.test --experimental-test-coverage --test-coverage-lines=80 --test-coverage-branches=80 --test-coverage-functions=90 --test-coverage-exclude=\"src/test/**\" --test-coverage-exclude=\"**/*.test.ts\" --test \"**/*.test.ts\"",
    "test": "pnpm clean && pnpm build && pnpm test:setup && pnpm test:run"
  },
  "dependencies": {
    "@nestjs/common": "catalog:",
    "@nestjs/core": "catalog:",
    "@nestjs/platform-express": "catalog:",
    "@nestjs/swagger": "catalog:",
    "@nestjs/platform-fastify": "^11.1.21",
    "@mikro-orm/core": "catalog:",
    "@mikro-orm/migrations": "catalog:",
    "@mikro-orm/nestjs": "catalog:",
    "@mikro-orm/postgresql": "catalog:",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.33",
    "@types/qs": "^6.15.1",
    "fastify": "^5.8.5",
    "pg": "^8.21.0",
    "qs": "^6.15.2",
    "reflect-metadata": "catalog:",
    "rxjs": "catalog:"
  },
  "devDependencies": {
    "@nestjs/cli": "catalog:",
    "@nestjs/schematics": "catalog:",
    "@nestjs/testing": "catalog:",
    "@types/express": "catalog:",
    "@types/node": "catalog:",
    "@types/sinon": "catalog:",
    "@types/supertest": "catalog:",
    "expect": "catalog:",
    "globals": "catalog:",
    "rimraf": "^6.1.3",
    "sinon": "catalog:",
    "source-map-support": "catalog:",
    "supertest": "catalog:",
    "ts-loader": "catalog:",
    "ts-node": "catalog:",
    "tsconfig-paths": "catalog:",
    "tsx": "catalog:"
  }
}
