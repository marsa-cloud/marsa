{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", "helpers:pinGitHubActionDigests"],
  "automerge": true,
  "platformAutomerge": true,
  "packageRules": [
    { "matchPackageNames": ["*"], "minimumReleaseAge": "7 days" },
    { "matchUpdateTypes": ["major"], "automerge": false },
    { "groupName": "NestJS", "matchPackagePatterns": ["^@nestjs/"] },
    { "groupName": "Nuxt", "matchPackagePatterns": ["^nuxt$", "^@nuxt/"] },
    { "groupName": "MikroORM", "matchPackagePatterns": ["^@mikro-orm/"] },
    {
      "groupName": "Node.js runtime",
      "matchPackageNames": ["node"],
      "matchManagers": ["dockerfile", "nvm"]
    }
  ]
}
