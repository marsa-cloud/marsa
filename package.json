{
  "name": "marsa",
  "version": "0.0.0",
  "private": true,
  "description": "Open-source, self-hostable Platform as a Service (PaaS)",
  "license": "AGPL-3.0",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@9.15.0",
  "pnpm": {
    "overrides": {
      "shell-quote@<1.8.4": ">=1.8.4",
      "@xhmikosr/decompress@<11.1.3": ">=11.1.3"
    }
  },
  "scripts": {
    "clean": "pnpm -r --parallel run clean",
    "lint": "pnpm -r --parallel run lint",
    "lint:root": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "dev": "pnpm --parallel --filter api --filter web dev",
    "dev:api": "pnpm --filter api dev",
    "dev:web": "pnpm --filter web dev",
    "seed": "node --env-file=apps/api/.env apps/api/dist/src/entrypoints/seed-dev.js",
    "build": "pnpm -r run build",
    "build:api": "pnpm --filter api build",
    "build:web": "pnpm --filter web build",
    "test": "pnpm -r --parallel run test",
    "e2e:up": "bash scripts/e2e-up.sh",
    "e2e:test": "bash scripts/e2e-test.sh",
    "e2e:down": "bash scripts/e2e-down.sh"
  },
  "devDependencies": {
    "@eslint/js": "catalog:",
    "eslint": "catalog:",
    "eslint-config-prettier": "catalog:",
    "eslint-plugin-simple-import-sort": "catalog:",
    "eslint-plugin-unused-imports": "catalog:",
    "prettier": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:"
  }
}
